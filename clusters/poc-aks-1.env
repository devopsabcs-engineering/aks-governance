# Per-cluster input for workload cluster poc-aks-1 (CAPZ aks-aso flavor).
# Consumed by scripts/provision-clusters.ps1 via clusterctl generate cluster
# --from clusters/cluster-template-aks-aso.yaml. Each KEY=VALUE becomes an
# environment variable substituted into the ${VAR} placeholders of the template.

CLUSTER_NAME=poc-aks-1
AZURE_LOCATION=eastus2

# Region-valid K8s version. eastus2 offers AKS up to 1.36.0 (default 1.34.8),
# verified by scripts/preflight.ps1 on 2026-06-14. Must be >= v1.28.0 to pass the
# Kyverno minimum-version governance policy.
KUBERNETES_VERSION=v1.34.8

# ASO authenticates via the GLOBAL credential (aso-controller-settings in capz-system,
# populated with the UAMI Workload Identity by scripts/deploy-mgmt.ps1). No per-resource
# credential Secret is required, so ASO_CREDENTIAL_SECRET_NAME is intentionally unset.

# System node pool sizing.
AZURE_NODE_MACHINE_TYPE=Standard_D2s_v6
WORKER_MACHINE_COUNT=2
